---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('posts'))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<BaseLayout title="MDX 博客" description="ZGDisZhengguidong 的 Astro + MDX 文章列表。">
  <section class="page-hero">
    <p class="section-kicker">Blog</p>
    <h1>新的 MDX 博客</h1>
    <p>后续新增文章建议优先写进 `src/content/posts/`，让博客主题逐步向大模型、智能体和对话系统方向收拢。</p>
  </section>

  <section class="featured-grid">
    {posts.map((post) => (
      <a class="feature-link surface-card" href={`/blog/${post.id}/`}>
        <span class="feature-tag">{post.data.category}</span>
        <h3>{post.data.title}</h3>
        <p>{post.data.description}</p>
      </a>
    ))}
  </section>
</BaseLayout>
