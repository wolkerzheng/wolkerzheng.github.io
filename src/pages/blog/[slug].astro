---
import { getCollection, render } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts
    .filter((item) => !item.data.draft)
    .map((item) => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const publishDate = item.data.publishDate.toISOString().slice(0, 10);
---

<MainLayout title={item.data.title} description={item.data.description}>
  <article class="panel article">
    <span class="meta">{item.data.category} | {publishDate}</span>
    <h1>{item.data.title}</h1>
    <p>{item.data.description}</p>
    <div class="chip-list">
      {item.data.tags.map((tag: string) => (
        <span class="chip">{tag}</span>
      ))}
    </div>
    <div class="prose">
      <Content />
    </div>
  </article>
</MainLayout>
