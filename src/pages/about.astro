---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="About">
  <section class="panel">
    <h1>About</h1>
    <p>
      I focus on LLM research, agent engineering, and dialogue system architecture.
      This site is now a modern Astro + MDX blog for frontier AI engineering notes.
    </p>
    <div class="chip-list">
      <span class="chip">LLM</span>
      <span class="chip">Agent</span>
      <span class="chip">Dialogue</span>
      <span class="chip">Engineering</span>
    </div>
  </section>
</MainLayout>
