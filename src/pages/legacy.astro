---
import MainLayout from '../layouts/MainLayout.astro';
import { siteConfig } from '../data/site-config';
---

<MainLayout title="Legacy Hexo">
  <section class="panel">
    <h1>Legacy Hexo Archive</h1>
    <p>
      The original Hexo website is isolated under <code>/legacy-hexo/</code>.
      The new main site no longer mixes legacy routes.
    </p>
    <div class="actions">
      <a class="btn primary" href={siteConfig.legacyUrl}>Open Legacy Site</a>
      <a class="btn secondary" href="/blog/">Back to New Blog</a>
    </div>
  </section>
</MainLayout>
