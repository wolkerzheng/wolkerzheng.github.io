---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import { siteConfig } from '../data/site-config';

const posts = (await getCollection('posts'))
  .filter((item) => !item.data.draft)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const featured = posts.filter((item) => item.data.featured).slice(0, 3);
const latest = posts.slice(0, 6);
const categoryCount = posts.reduce<Record<string, number>>((acc, item) => {
  acc[item.data.category] = (acc[item.data.category] ?? 0) + 1;
  return acc;
}, {});
const categoryList = Object.entries(categoryCount).sort((a, b) => b[1] - a[1]);
const now = Date.now();
const isNewPost = (ts: number) => now - ts < 21 * 24 * 60 * 60 * 1000;
---

<MainLayout title="Home" description={siteConfig.description}>
  <section class="panel hero">
    <h1>New Blog Framework for Agent Era</h1>
    <p>
      The main site is rebuilt with Astro + MDX and now focuses on LLM systems,
      agent engineering, and dialogue architecture. The old Hexo site is archived
      as a standalone folder with a single entry link.
    </p>
    <div class="actions">
      <a class="btn primary" href="/blog/">Read Blog</a>
      <a class="btn secondary" href="/legacy/">Open Legacy Hexo</a>
    </div>
  </section>

  <section class="section">
    <h2>Featured</h2>
    <div class="grid cols-3">
      {(featured.length ? featured : latest.slice(0, 3)).map((post) => (
        <a class="card" href={`/blog/${post.id}/`}>
          <span class="meta">{post.data.category}</span>
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
          {isNewPost(post.data.publishDate.getTime()) && <div class="chip-list"><span class="chip">NEW</span></div>}
        </a>
      ))}
    </div>
  </section>

  <section class="section">
    <h2>Latest Posts</h2>
    <div class="grid cols-2">
      {latest.map((post) => (
        <a class="card" href={`/blog/${post.id}/`}>
          <span class="meta">{post.data.publishDate.toISOString().slice(0, 10)}</span>
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
          <div class="chip-list">
            {post.data.tags.slice(0, 3).map((tag) => (
              <span class="chip">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="section">
    <h2>Categories</h2>
    <div class="grid cols-3">
      {categoryList.map(([name, count]) => (
        <div class="card">
          <span class="meta">CATEGORY</span>
          <h3>{name}</h3>
          <p>{count} posts</p>
        </div>
      ))}
    </div>
  </section>
</MainLayout>
